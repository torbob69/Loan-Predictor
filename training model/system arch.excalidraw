      "boundElements": [],
      "updated": 1774922654726,
      "link": null,
      "locked": false,
      "text": "B = Beginning: The first word of the entity.\n\n\nI = Inside: Any subsequent words belonging to that same entity.\n\n\nO = Outside: Words that are not part of any entity.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "B = Beginning: The first word of the entity.\n\n\nI = Inside: Any subsequent words belonging to that same entity.\n\n\nO = Outside: Words that are not part of any entity.",
      "autoResize": true,
      "lineHeight": 1.25
    },
