      "updated": 1774922654726,
      "link": null,
      "locked": false,
      "text": " entities are often longer than a single word (like \"Barack Obama\"), models use the\nBIO Format to label the \"span\" of the entity",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " entities are often longer than a single word (like \"Barack Obama\"), models use the BIO Format to label the \"span\" of the entity",
      "autoResize": false,
      "lineHeight": 1.25
