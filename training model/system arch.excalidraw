          "type": "arrow"
        }
      ],
      "updated": 1774922654726,
      "link": null,
      "locked": false,
      "text": "Transformer based NER --> Uses existing language models like BERT or RoBERTa for contextual embedding",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Transformer based NER --> Uses existing language models like BERT or RoBERTa for contextual embedding",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "De8ZiELdpKe57IeBktDie",
      "type": "text",
      "x": 3310.3528487361164,
