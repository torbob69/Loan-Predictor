      "updated": 1774922654726,
      "link": null,
      "locked": false,
      "text": "for Lemmatization --> before we do lemmatizing, we need to understand the word's valid\ndictionary\n\nexample : \"leaves\" could be converted into \"leave\" or \"leaf\" depending on the POS we tagged",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "for Lemmatization --> before we do lemmatizing, we need to understand the word's valid dictionary\n\nexample : \"leaves\" could be converted into \"leave\" or \"leaf\" depending on the POS we tagged",
      "autoResize": false,
      "lineHeight": 1.25
    },
