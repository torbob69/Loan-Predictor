      "seed": 372185125,
      "version": 950,
      "versionNonce": 998313369,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774922654725,
      "link": null,
      "locked": false,
      "text": "Stopwords are words that frequently appear but they dont have any\nsignificant meaning to the text.\n\nExample : the, in, at, and, on, by, etc.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stopwords are words that frequently appear but they dont have any significant meaning to the text.\n\nExample : the, in, at, and, on, by, etc.",
      "autoResize": false,
      "lineHeight": 1.25
    },
