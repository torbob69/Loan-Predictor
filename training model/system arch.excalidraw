    {
      "id": "gMBUQUJLM7XHa9crDfklz",
      "type": "text",
      "x": 813.3753579246845,
      "y": 1510.973409788896,
      "width": 744.2232666015625,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "Mr96K76DcdDw1irj2VTCZ"
      ],
      "frameId": null,
      "index": "b0U",
      "roundness": null,
      "seed": 238787301,
      "version": 946,
      "versionNonce": 1401633625,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774922654725,
      "link": null,
      "locked": false,
      "text": "Lemmatization and Stemming both converts a word into its base word, example \"drinking\",\n\"drank\", \"drunk\" base word is \"drink\"\n\nLemmatization --> works by understanding the vocab, grammar, and context so it produces\nvalid words.\n\nStemming --> workd by rule based truncation and may not produce valid words.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Lemmatization and Stemming both converts a word into its base word, example \"drinking\", \"drank\", \"drunk\" base word is \"drink\"\n\nLemmatization --> works by understanding the vocab, grammar, and context so it produces valid words.\n\nStemming --> workd by rule based truncation and may not produce valid words.",
      "autoResize": false,
      "lineHeight": 1.25
    },
