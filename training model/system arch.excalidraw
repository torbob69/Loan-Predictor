    {
      "id": "gL3C0_AoR550BzfAXRIDu",
      "type": "text",
      "x": 3299.026595428161,
      "y": 1329.4695970404484,
      "width": 843.6193237304688,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1s",
      "roundness": null,
      "seed": 2111575429,
      "version": 700,
      "versionNonce": 1838695481,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "1FFT-snHojr_zO7zOXRMe",
          "type": "arrow"
        }
      ],
      "updated": 1774922654726,
      "link": null,
      "locked": false,
      "text": "Ruled based NER --> uses handcrafted patterns, dictionaries, and regular expressions.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ruled based NER --> uses handcrafted patterns, dictionaries, and regular expressions.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "0Jxzu8vYAor4Ew270_QnP",
      "type": "text",
      "x": 3300.3255756777426,
      "y": 1386.4216768892982,
      "width": 1047.3993553436849,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1t",
      "roundness": null,
      "seed": 52723467,
      "version": 941,
      "versionNonce": 170391511,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "D9LA1puY8qMJty3_s-3sr",
          "type": "arrow"
        }
      ],
      "updated": 1774922654726,
      "link": null,
      "locked": false,
      "text": "Statistical NER (ML) --> requires human-annotated training data and learn by extracting features like the\nsurrounding context window, POS tags, and prefixes. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Statistical NER (ML) --> requires human-annotated training data and learn by extracting features like the surrounding context window, POS tags, and prefixes. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "43O8u-Tp86_ARCcuMAWzL",
      "type": "text",
      "x": 3304.393044627876,
