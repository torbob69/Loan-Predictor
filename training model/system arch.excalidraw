      "isDeleted": true,
      "boundElements": [],
      "updated": 1774922654726,
      "link": null,
      "locked": false,
      "text": "for Parsing --> Parsers use POS tags to build syntax trees. A syntax\ntree is a diagram that maps out the grammatical structure of a\nsentence, breaking it down into noun phrases, verb phrases, subjects,\nand objects.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "for Parsing --> Parsers use POS tags to build syntax trees. A syntax tree is a diagram that maps out the grammatical structure of a sentence, breaking it down into noun phrases, verb phrases, subjects, and objects.",
      "autoResize": false,
      "lineHeight": 1.25
    },
